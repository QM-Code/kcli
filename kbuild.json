{
  "kbuild": {
    "rootdir": "../kbuild",
    "api": "1"
  },
  "project": {
    "title": "Karma CLI Tools",
    "id": "kcli"
  },
  "git": {
    "url": "https://github.com/QM-Code/kcli",
    "auth": "git@github.com:QM-Code/kcli.git"
  },
  "cmake": {
    "minimum_version": "3.20",
    "sdk": {
      "package_name": "KcliSDK"
    }
  },
  "vcpkg": {
    "dependencies": [
      "spdlog"
    ]
  },
  "build": {
    "jobs": 4,
    "type": "shared",
    "demos": [
      "bootstrap",
      "libraries/alpha",
      "libraries/beta",
      "libraries/gamma",
      "executable"
    ],
    "defaults": {
      "demos": [
        "bootstrap",
        "libraries/alpha",
        "libraries/beta",
        "libraries/gamma",
        "executable"
      ]
    }
  }
}
